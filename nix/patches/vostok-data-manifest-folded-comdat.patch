+/// Two definitions that are one folded COMDAT claimed by two objects: the linker
+/// emitted the payload into each referencing object and folded them onto a single
+/// surviving rva. Mirrors `data_section_manifest::compatible_folded_comdat_alias`
+/// for the definitions those sections carry; only external definitions fold.
+fn folded_comdat_alias(first: &DataDefinition, second: &DataDefinition) -> bool {
+    first.object != second.object
+        && first.rva == second.rva
+        && first.size == second.size
+        && first.name.as_bytes() == second.name.as_bytes()
+        && first.storage == second.storage
+        && first.alignment == second.alignment
+        && first.scope == DataScope::External
+        && second.scope == DataScope::External
+}
