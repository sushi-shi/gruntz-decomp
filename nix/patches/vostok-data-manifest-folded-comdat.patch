+    #[test]
+    fn accepts_one_folded_comdat_claimed_by_several_objects() {
+        // cl.exe emits a string literal into EVERY object that uses it; the linker
+        // folds them onto one rva. All owners are correct, so each target object
+        // must receive its own copy.
+        let text = format!(
+            "{HEADER_TEXT}??_C@_09LDCC@LogicBump?$AA@\tone.c\t0x100\t10\trdata\t4\t-\texternal\tcandidate-COFF-string\n\
+             ??_C@_09LDCC@LogicBump?$AA@\ttwo.c\t0x100\t10\trdata\t4\t-\texternal\tcandidate-COFF-string\n\
+             ??_C@_09LDCC@LogicBump?$AA@\tthree.c\t0x100\t10\trdata\t4\t-\texternal\tcandidate-COFF-string\n"
+        );
+        let parsed = parse(&text).unwrap();
+        assert_eq!(parsed.definitions().len(), 3);
+        // Owner resolution stays well defined: every copy answers with one identity.
+        let (owner, addend) = parsed.owner_and_addend_for_rva(0x104).unwrap();
+        assert_eq!(owner.name.as_bytes(), b"??_C@_09LDCC@LogicBump?$AA@");
+        assert_eq!(addend, 4);
+    }
+
