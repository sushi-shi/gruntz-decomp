# clangd over the GENERATED clang-cl compilation database. This is ADDITIVE
# editor tooling (go-to-def / completion / hover / diagnostics) that runs
# alongside the real matching build - it does NOT drive or verify it. The Wine
# MSVC 5.0 build (scripts/cc_wrap.py) is the sole verdict on correctness; clang
# is only a READER of this MSVC5-dialect code.
#
# Generate the DB first:  python3 scripts/gen_clangd.py   (see docs/clangd.md)
CompileFlags:
  # Point at build/clangd/ (NOT the repo root) so we never collide with the
  # matching build's own repo-root compile_commands.json (the cl-under-wine one
  # emitted by configure.py). gen_clangd.py writes build/clangd/compile_commands.json.
  CompilationDatabase: build/clangd
  Add:
    # Emulate MSVC 5.0 (cl 11.00 == _MSC_VER 1100) so the ancient MFC 4.2 / CRT
    # headers take their MSVC-version codepaths. Mirrors gen_clangd.py; also
    # applies when clangd opens a header with no direct compdb entry.
    - --target=i386-pc-windows-msvc
    - -fms-compatibility-version=11.00
    - -fms-extensions
    - -fdelayed-template-parsing
    # The MFC/CRT headers trip dialect errors clang's compat mode cannot be
    # talked out of, and their knock-on cascades blow past clangd's default
    # ~20-error limit - which ABORTS the parse mid-TU and loses the AST below
    # the abort point. clangd's command mangler drops this flag when it comes
    # from the compdb, so it MUST live here.
    - -ferror-limit=0

Diagnostics:
  # The toolchain headers are reached via /imsvc (system includes), so clangd
  # already silences diagnostics that ORIGINATE inside MFC/CRT/DirectX headers.
  # The settings below tame the few clang-cl warnings that still leak through
  # MSVC5-dialect code without hiding genuine problems in our own src/ sources.
  Suppress:
    # MSVC lets a non-virtual dtor be called through a base ptr etc.; the old
    # MFC headers lean on several such MSVC-isms that are not actionable here.
    - -Wmicrosoft
    - -Wignored-pragmas
    - -Wpragma-pack
    - -Wnonportable-include-path
  UnusedIncludes: None
  ClangTidy:
    Remove: "*"
